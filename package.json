{
  "name": "x-following-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fetch, deduplicate, and summarize recent posts from selected X accounts.",
  "scripts": {
    "scan": "node --use-env-proxy scripts/x-radar.mjs",
    "scan:dry": "node --use-env-proxy scripts/x-radar.mjs --dry-run",
    "scan:feed": "node --use-env-proxy scripts/x-radar.mjs --feed-only --dry-run",
    "cost": "node scripts/x-radar.mjs --estimate-cost",
    "dashboard": "node scripts/serve-dashboard.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
